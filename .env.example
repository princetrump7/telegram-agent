# ─── Required ───────────────────────────────────────────────────────
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# AI API key — pick one provider:
#
# Option A: OpenCode Zen (free, no CC needed) — https://opencode.ai
#   Set the key and leave the default base URL
#   Free models: deepseek-v4-flash-free, qwen-2-5-72b-instruct-free
#
# Option B: OpenRouter (free tier, no CC needed) — https://openrouter.ai/keys
#   Change OPENCODE_BASE_URL to https://openrouter.ai/api/v1
#   Free models: google/gemini-2.0-flash-exp:free, meta-llama/llama-3.2-3b-instruct:free
#
# Option C: Any OpenAI-compatible API (your own key)
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://opencode.ai/zen/v1

# ─── Optional — AI Model ───────────────────────────────────────────
# Primary model. The bot falls back to google/gemini-2.0-flash-exp:free
# automatically if this model returns empty responses.
AI_MODEL=deepseek-v4-flash-free
MAX_TOKENS=1024

# ─── Optional — Memory ─────────────────────────────────────────────
# How many message pairs to remember per conversation
MEMORY_SIZE=20

# ─── Optional — System Prompt ──────────────────────────────────────
# Leave empty for the default
# SYSTEM_PROMPT=You are a helpful assistant.

# ─── Optional — Webhook (production) ───────────────────────────────
WEBHOOK_URL=
WEBHOOK_PORT=8080

# ─── Optional — Other ──────────────────────────────────────────────
LOG_LEVEL=INFO
RATE_LIMIT_SECONDS=1.0
